<Window
    x:Class="PhotoViewer.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="{x:Bind ViewModel.WindowTitle, Mode=OneWay}">

    <Grid x:Name="RootGrid"
          KeyDown="RootGrid_KeyDown"
          IsTabStop="True"
          Loaded="RootGrid_Loaded">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition x:Name="InfoPanelColumn" Width="0" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <!-- Image layer -->
            <Image x:Name="MainImage"
                   Source="{x:Bind ViewModel.DisplayImage, Mode=OneWay}"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   RenderTransformOrigin="0.5,0.5"
                   Margin="20"
                   PointerWheelChanged="MainImage_PointerWheelChanged"
                   PointerPressed="MainImage_PointerPressed"
                   PointerMoved="MainImage_PointerMoved"
                   PointerReleased="MainImage_PointerReleased"
                   DoubleTapped="MainImage_DoubleTapped">
                <Image.RenderTransform>
                    <CompositeTransform x:Name="ImageTransform" />
                </Image.RenderTransform>
            </Image>

            <!-- Sol / sağ kenar: tam yükseklik gezinti (ekran kenarına tıklama) -->
            <Button HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    Width="88"
                    Margin="0"
                    Padding="0"
                    Background="#22000000"
                    BorderThickness="0"
                    Opacity="1"
                    Command="{x:Bind ViewModel.PreviousPhotoCommand}"
                    ToolTipService.ToolTip="Önceki (←)">
                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                          Glyph="&#xE72B;"
                          FontSize="28"
                          Foreground="#CCFFFFFF"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
            </Button>
            <Button HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Width="88"
                    Margin="0"
                    Padding="0"
                    Background="#22000000"
                    BorderThickness="0"
                    Command="{x:Bind ViewModel.NextPhotoCommand}"
                    ToolTipService.ToolTip="Sonraki (→)">
                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                          Glyph="&#xE72A;"
                          FontSize="28"
                          Foreground="#CCFFFFFF"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
            </Button>

            <!-- Alt orta: sıra + durum -->
            <StackPanel VerticalAlignment="Bottom"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16"
                        Padding="12,8"
                        Background="#99000000"
                        CornerRadius="8"
                        Spacing="4">
                <TextBlock Text="{x:Bind ViewModel.NavigationInfo, Mode=OneWay}"
                           HorizontalAlignment="Center"
                           Foreground="White"
                           FontSize="14"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           TextWrapping="Wrap"
                           MaxWidth="520"
                           FontSize="12"
                           Foreground="#FFFFB74D"
                           HorizontalAlignment="Center"
                           IsTextSelectionEnabled="True"/>
            </StackPanel>

            <!-- Overlay: info, zoom -->
            <StackPanel Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20">
                <Border Background="#CC222222" CornerRadius="8" Padding="0" Margin="0,0,0,12" Width="48" Height="48">
                    <Button x:Name="InfoButton"
                            Click="InfoButton_Click"
                            Width="48" Height="48"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTipService.ToolTip="Bilgileri Göster/Gizle">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE946;" FontSize="24" Foreground="White"/>
                    </Button>
                </Border>
                <Border x:Name="ZoomIndicatorBorder"
                        Visibility="Collapsed"
                        Background="#CC222222"
                        CornerRadius="8"
                        Padding="0"
                        Width="48" Height="48"
                        Opacity="0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                        <TextBlock x:Name="ZoomIndicatorText"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Text="0%"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <Border x:Name="InfoPanel"
                Grid.Column="1" 
                Visibility="Collapsed"
                Background="{ThemeResource SystemControlAcrylicElementBrush}" 
                BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}" 
                BorderThickness="1,0,0,0">
            <Grid Padding="20" Width="350">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="EXIF Detayları"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,12"/>

                <StackPanel Grid.Row="1" Spacing="12">
                    <!-- Dosya adı -->
                    <Border Background="#CC222222" CornerRadius="6" Padding="8" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                            <FontIcon Glyph="&#xE8B7;" FontSize="16" Foreground="White" />
                            <TextBlock Text="Dosya adı" FontSize="12" Foreground="#FFD7D7D7" />
                            <TextBlock Text="{x:Bind ViewModel.FileDisplayName, Mode=OneWay}" FontSize="14" FontWeight="SemiBold" Foreground="White" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- Kamera marka-model bilgisi -->
                    <Border Background="#CC222222" CornerRadius="6" Padding="8" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                            <FontIcon Glyph="&#xE722;" FontSize="16" Foreground="White" />
                            <TextBlock Text="Kamera" FontSize="12" Foreground="#FFD7D7D7" />
                            <TextBlock Text="{x:Bind ViewModel.Camera, Mode=OneWay}" FontSize="14" FontWeight="SemiBold" Foreground="White" />
                        </StackPanel>
                    </Border>

                    <!-- Çözünürlük -->
                    <Border Background="#CC222222" CornerRadius="6" Padding="8" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                            <FontIcon Glyph="&#xE8B6;" FontSize="16" Foreground="White" />
                            <TextBlock Text="Çözünürlük" FontSize="12" Foreground="#FFD7D7D7" />
                            <TextBlock Text="{x:Bind ViewModel.Resolution, Mode=OneWay}" FontSize="14" FontWeight="SemiBold" Foreground="White" />
                        </StackPanel>
                    </Border>

                    <!-- Dosya boyutu -->
                    <Border Background="#CC222222" CornerRadius="6" Padding="8" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                            <FontIcon Glyph="&#xE7C3;" FontSize="16" Foreground="White" />
                            <TextBlock Text="Dosya Boyutu" FontSize="12" Foreground="#FFD7D7D7" />
                            <TextBlock Text="{x:Bind ViewModel.FileSize, Mode=OneWay}" FontSize="14" FontWeight="SemiBold" Foreground="White" />
                        </StackPanel>
                    </Border>

                    <!-- Koordinatlar -->
                    <Border Background="#CC222222" CornerRadius="6" Padding="8" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                            <FontIcon Glyph="&#xE707;" FontSize="16" Foreground="White" />
                            <TextBlock Text="Koordinatlar" FontSize="12" Foreground="#FFD7D7D7" />
                            <TextBlock Text="{x:Bind ViewModel.Coordinates, Mode=OneWay}" FontSize="14" FontWeight="SemiBold" Foreground="White" />
                        </StackPanel>
                    </Border>

                    <!-- GPS Altitude -->
                    <Border Background="#CC222222" CornerRadius="6" Padding="8" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                            <FontIcon Glyph="&#xE81E;" FontSize="16" Foreground="White" />
                            <TextBlock Text="GPS Altitude" FontSize="12" Foreground="#FFD7D7D7" />
                            <TextBlock Text="{x:Bind ViewModel.GpsAltitude, Mode=OneWay}" FontSize="14" FontWeight="SemiBold" Foreground="White" />
                        </StackPanel>
                    </Border>

                    <!-- Fotoğraf formatı indicator -->
                    <Border Background="#CC222222" CornerRadius="6" Padding="8" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                            <FontIcon Glyph="&#xE8FD;" FontSize="16" Foreground="White" />
                            <TextBlock Text="Format" FontSize="12" Foreground="#FFD7D7D7" />
                            <TextBlock Text="{x:Bind ViewModel.Format, Mode=OneWay}" FontSize="14" FontWeight="SemiBold" Foreground="White" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
